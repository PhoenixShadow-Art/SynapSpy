    }, entry)
    addCorner(entry:FindFirstChild("Frame") or entry, 2)

    makeInstance("TextLabel", {
        Text             = string.format("[%s] %s → %s", formatTime(), name, action),
        TextColor3       = THEME.TEXT_PRIMARY,
        BackgroundTransparency = 1,
        Font             = Enum.Font.GothamBold,
