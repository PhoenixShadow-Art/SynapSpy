-- ============================================================
local function getFullPath(obj)
    if not obj then return "nil" end
    local path = obj.Name
    local parent = obj.Parent
    while parent and parent ~= game do
        path = parent.Name .. "." .. path
        parent = parent.Parent
    end
    return "game." .. path
end

local function formatTime()
    local t = os.time()
    return os.date("%H:%M:%S", t)
end

local function formatArgs(args)
    local parts = {}
    for i, v in ipairs(args) do
        local t = typeof(v)
        if t == "string" then
            parts[i] = string.format('"%s"', tostring(v):sub(1, 40))
        elseif t == "Instance" then
            parts[i] = string.format('[Instance] %s', v:GetFullName())
        elseif t == "table" then
            parts[i] = "[table]"
        elseif t == "Vector3" then
            parts[i] = string.format("Vector3(%g,%g,%g)", v.X, v.Y, v.Z)
        elseif t == "CFrame" then
            parts[i] = string.format("CFrame(%g,%g,%g)", v.X, v.Y, v.Z)
        elseif t == "Color3" then
            parts[i] = string.format("Color3(%d,%d,%d)",
                math.floor(v.R*255), math.floor(v.G*255), math.floor(v.B*255))
        else
            parts[i] = tostring(v)
        end
    end
    return table.concat(parts, ", ")
end

-- Parse a simple argument string into a Lua value
local function parseArg(str)
    str = str:match("^%s*(.-)%s*$") -- trim
    if str == "true"  then return true  end
    if str == "false" then return false end
    if str == "nil"   then return nil   end
    -- number
    local n = tonumber(str)
    if n then return n end
    -- Vector3
    local x,y,z = str:match("^Vector3%(([%d%.%-]+),([%d%.%-]+),([%d%.%-]+)%)$")
    if x then return Vector3.new(tonumber(x), tonumber(y), tonumber(z)) end
    -- Color3
    local r,g,b = str:match("^Color3%(([%d%.%-]+),([%d%.%-]+),([%d%.%-]+)%)$")
    if r then return Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b)) end
    -- Instance path
    if str:sub(1,5) == "game." then
        local ok, inst = pcall(function()
            local parts = str:sub(6):split(".")
            local obj = game
            for _, p in ipairs(parts) do obj = obj[p] end
            return obj
        end)
        if ok then return inst end
    end
    -- default: string (strip quotes if present)
    return str:match('^"(.*)"$') or str:match("^'(.*)'$") or str
end

local function parseArgs(argString)
    local args = {}
    -- Simple split by comma (not inside brackets)
    local depth = 0
    local current = ""
    for i = 1, #argString do
        local c = argString:sub(i,i)
        if c == "(" or c == "{" or c == "[" then depth = depth + 1
        elseif c == ")" or c == "}" or c == "]" then depth = depth - 1
        end
        if c == "," and depth == 0 then
            local v = parseArg(current)
            if v ~= nil then table.insert(args, v) end
            current = ""
        else
            current = current .. c
        end
    end
    if current:match("%S") then
        local v = parseArg(current)
        if v ~= nil then table.insert(args, v) end
    end
    return args
end

