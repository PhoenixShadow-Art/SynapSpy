-- ============================================================
-- REMOTE DATA & HOOKING ENGINE
-- ============================================================
-- We hook FireServer / InvokeServer via metatable to passively log calls.
local hookedMeta = {}

local originalFireServer   = nil
local originalInvokeServer = nil

local function hookRemoteMethods()
    -- Hook RemoteEvent:FireServer
    local reMeta = getmetatable(Instance.new("RemoteEvent"))
    if reMeta then
        originalFireServer = reMeta.__index.FireServer
        reMeta.__index.FireServer = function(self, ...)
            local args = {...}
            if State.spyEnabled then
                local rd = State.remotes[self]
                if rd then
                    if rd.blocked then return end -- block if flagged
                    rd.fireCount = rd.fireCount + 1
                    rd.lastFired = formatTime()
                    addLogEntry(self, "Fired", args)
                    -- refresh UI row
                    updateRemoteRow(self)
                end
            end
            return originalFireServer(self, table.unpack(args))
        end
        hookedMeta.re = true
    end

    -- Hook RemoteFunction:InvokeServer
    local rfMeta = getmetatable(Instance.new("RemoteFunction"))
    if rfMeta then
        originalInvokeServer = rfMeta.__index.InvokeServer
        rfMeta.__index.InvokeServer = function(self, ...)
            local args = {...}
            if State.spyEnabled then
                local rd = State.remotes[self]
                if rd then
                    if rd.blocked then return nil end
                    rd.fireCount = rd.fireCount + 1
                    rd.lastFired = formatTime()
                    addLogEntry(self, "Invoked", args)
                    updateRemoteRow(self)
                end
            end
            return originalInvokeServer(self, table.unpack(args))
        end
        hookedMeta.rf = true
    end
end

