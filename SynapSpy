local logIndex = 0

function addLogEntry(remote, action, args)
    logIndex = logIndex + 1
    local rd = State.remotes[remote]
    local name = remote and remote.Name or "?"
    local rtype = rd and rd.remoteType or "?"
    local color = (rtype == "RemoteEvent") and THEME.LOG_EVENT or THEME.LOG_FUNC
    if rd and rd.blocked then color = THEME.LOG_BLOCKED end

    local entry = makeInstance("Frame", {
        Name             = "LogEntry_" .. logIndex,
        Size             = UDim2.new(1, -8, 0, 42),
        BackgroundColor3 = THEME.BG_ITEM,
