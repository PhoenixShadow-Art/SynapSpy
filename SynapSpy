        TextXAlignment   = Enum.TextXAlignment.Left,
        TextTruncate     = Enum.TextTruncate.AtEnd,
        ZIndex           = 3,
    }, entry)

    local argsStr = formatArgs(args)
    if #argsStr == 0 then argsStr = "(no args)" end
    makeInstance("TextLabel", {
        Text             = argsStr,
        TextColor3       = THEME.TEXT_MUTED,
        BackgroundTransparency = 1,
        Font             = Enum.Font.Code,
        TextSize         = 9,
