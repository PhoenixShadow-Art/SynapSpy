-- ============================================================
-- REMOTE SCANNER
-- ============================================================
local function registerRemote(obj)
    if State.remotes[obj] then return end -- already tracked
    local isEvent = obj:IsA("RemoteEvent")
    local isFunc  = obj:IsA("RemoteFunction")
    if not (isEvent or isFunc) then return end

    State.remotes[obj] = {
        remoteType = isEvent and "RemoteEvent" or "RemoteFunction",
        fireCount  = 0,
        lastFired  = nil,
        blocked    = false,
        spying     = true,
    }
    buildRemoteRow(obj)
    updateRemoteCount()
end

local function scanDescendants(root)
    for _, obj in ipairs(root:GetDescendants()) do
        pcall(registerRemote, obj)
    end
    root.DescendantAdded:Connect(function(obj)
        task.defer(function() pcall(registerRemote, obj) end)
    end)
end

local function fullScan()
    -- Scan common locations
    scanDescendants(ReplicatedStorage)
    scanDescendants(game:GetService("Players"))
    pcall(function() scanDescendants(game:GetService("Workspace")) end)
    pcall(function() scanDescendants(game:GetService("ReplicatedFirst")) end)
    pcall(function() scanDescendants(game:GetService("StarterGui")) end)
    pcall(function() scanDescendants(game:GetService("Teams")) end)
    pcall(function() scanDescendants(game:GetService("Chat")) end)
    -- Try all top-level services
    for _, child in ipairs(game:GetChildren()) do
        pcall(scanDescendants, child)
    end
end

-- ============================================================
-- FILTER / SEARCH APPLY
-- ============================================================
local function applyFilters()
    local q = State.searchQuery:lower()
    for remote, rd in pairs(State.remotes) do
        local row = remoteRows[remote]
        if row then
            local matchType = (State.filterType == "All")
                or (State.filterType == "RemoteEvent" and rd.remoteType == "RemoteEvent")
                or (State.filterType == "RemoteFunction" and rd.remoteType == "RemoteFunction")
            local matchSearch = (q == "") or remote.Name:lower():find(q, 1, true)
            row.Visible = matchType and (matchSearch ~= nil)
        end
    end
end

-- ============================================================
-- POPUP FIRE LOGIC
-- ============================================================
local function fireActiveTarget()
    if not activeFireTarget then return end
    local remote = activeFireTarget
    local rd = State.remotes[remote]
    if not rd then return end

    local argStr = PopupArgBox.Text
    local args = parseArgs(argStr)

    local ok, err = pcall(function()
        if rd.remoteType == "RemoteEvent" then
            remote:FireServer(table.unpack(args))
        else
            local result = remote:InvokeServer(table.unpack(args))
            PopupResultLabel.TextColor3 = THEME.SUCCESS
            PopupResultLabel.Text = "Return: " .. tostring(result):sub(1, 60)
        end
    end)

    if ok then
        if rd.remoteType == "RemoteEvent" then
            PopupResultLabel.TextColor3 = THEME.SUCCESS
            PopupResultLabel.Text = "✓ Fired successfully!"
        end
    else
        PopupResultLabel.TextColor3 = THEME.DANGER
        PopupResultLabel.Text = "✗ Error: " .. tostring(err):sub(1, 80)
    end
end

PopupFireBtn.MouseButton1Click:Connect(fireActiveTarget)
